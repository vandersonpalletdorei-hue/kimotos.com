{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "kimotos/package.json",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    {
      "src": "/api/shipping/calculate",
      "dest": "api/index.ts"
    },
    {
      "src": "/api/products",
      "dest": "api/index.ts"
    },
    {
      "src": "/api/categories",
      "dest": "api/index.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "kimotos/$1"
    }
  ]
}
